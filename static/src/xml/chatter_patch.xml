<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">

  <!-- ============================================================
       Diálogo OWL: selector de formato y título del nuevo archivo
       ============================================================ -->
  <t t-name="onlyoffice_chatter.CreateDialog" owl="1">
    <div>
      <Dialog
        title="dialogTitle"
        contentClass="'o-oo-chatter-create-dialog'"
        footer="true"
      >
        <!-- Nombre del documento -->
        <div class="mb-3">
          <label class="o_form_label fw-bold" for="oo_chatter_title">
            <t t-esc="labels.title"/>
          </label>
          <input
            class="o_input form-control mt-1"
            id="oo_chatter_title"
            t-model.trim="state.title"
            type="text"
            autocomplete="off"
            t-ref="autofocus"
            t-att-placeholder="labels.placeholder"
          />
        </div>

        <!-- Selector de formato -->
        <div class="d-flex gap-3 justify-content-center py-2">
          <t t-foreach="formats" t-as="fmt" t-key="fmt.ext">
            <div
              role="button"
              tabindex="0"
              class="o-oo-format-card d-flex flex-column align-items-center p-2 rounded cursor-pointer"
              t-att-class="state.selectedFormat === fmt.ext ? 'o-oo-format-selected border border-primary' : 'border border-transparent'"
              t-on-click="() => this.selectFormat(fmt.ext)"
              t-on-dblclick="() => this.createFile()"
              t-on-keydown="(ev) => this.handleFormatKeydown(fmt.ext, ev)"
            >
              <img
                class="o-oo-format-icon mb-1"
                t-att-src="'/onlyoffice_odoo_documents/static/svg/formats/' + fmt.ext + '.svg'"
                t-att-alt="fmt.label"
                style="width: 48px; height: 48px;"
              />
              <span class="small text-muted" t-esc="fmt.label"/>
            </div>
          </t>
        </div>

        <t t-set-slot="footer">
          <button
            class="btn btn-primary"
            t-att-disabled="isButtonDisabled()"
            t-on-click="() => this.createFile()"
          >
            <t t-if="state.isCreating">
              <span class="spinner-border spinner-border-sm me-1" role="status"/>
              <t t-esc="labels.creating"/>
            </t>
            <t t-else="">
              <t t-esc="labels.create"/>
            </t>
          </button>
          <button class="btn btn-secondary" t-on-click="data.close">
            <t t-esc="labels.cancel"/>
          </button>
        </t>
      </Dialog>
    </div>
  </t>

  <!-- ============================================================
       Herencia de mail.Chatter — inyecta el botón "Nuevo"
       ============================================================ -->
  <t t-name="onlyoffice_chatter.ChatterPatch"
     t-inherit="mail.Chatter"
     t-inherit-mode="extension">
    <xpath expr="//button[hasclass('o-mail-Chatter-activity')]" position="after">
      <button
        type="button"
        class="btn btn-secondary text-nowrap ms-1"
        t-att-class="{ 'my-2': !props.compactHeight }"
        t-att-title="ooLabels.buttonTitle"
        t-on-click="openOnlyofficeDialog"
      >
        <i class="fa fa-file-o me-1" aria-hidden="true"/>
        <t t-esc="ooLabels.buttonText"/>
      </button>
    </xpath>
  </t>

</templates>
