<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ============================================================
         QWeb template for the creation dialog (legacy Widget)
         ============================================================ -->
    <template id="onlyoffice_chatter.CreateDialog">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content o-oo-chatter-create-dialog">
                <div class="modal-header">
                    <h5 class="modal-title">Create with ONLYOFFICE</h5>
                </div>
                <div class="modal-body">
                    <!-- Document title -->
                    <div class="mb-3">
                        <label class="o_form_label fw-bold" for="oo_chatter_title">Title</label>
                        <input
                            class="o_input form-control mt-1"
                            id="oo_chatter_title"
                            type="text"
                            autocomplete="off"
                            placeholder="New Document"
                            value="New Document"
                        />
                    </div>
                    <!-- Format selector -->
                    <div class="d-flex gap-3 justify-content-center py-2">
                        <t t-foreach="widget.formats" t-as="fmt">
                            <div
                                role="button"
                                tabindex="0"
                                t-att-data-ext="fmt.ext"
                                class="o-oo-format-card d-flex flex-column align-items-center p-2 rounded cursor-pointer border border-transparent"
                            >
                                <i t-attf-class="fa #{fmt.icon} o-oo-format-icon mb-1"
                                   role="img" t-att-aria-label="fmt.label"/>
                                <span class="small text-muted" t-esc="fmt.label"/>
                            </div>
                        </t>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary">
                        <span class="spinner-border spinner-border-sm me-1 d-none" role="status"/>
                        <span class="o-oo-btn-text">Create</span>
                    </button>
                    <button type="button" class="btn btn-secondary">Cancel</button>
                </div>
            </div>
        </div>
    </template>

    <!-- ============================================================
         Inject "New" button into Chatter topbar
         Odoo 15: mail.chatter.Topbar template
         ============================================================ -->
    <template id="onlyoffice_chatter.chatter_button"
              inherit_id="mail.chatter.Topbar"
              name="OnlyOffice New Button">
        <xpath expr="//div[hasclass('o_topbar_right_area')]" position="inside">
            <button type="button"
                    class="btn btn-secondary text-nowrap ms-1 o_mail_chatter_button_oo_new"
                    title="Create OnlyOffice Document">
                <i class="fa fa-file-o me-1" aria-hidden="true"/>
                New
            </button>
        </xpath>
    </template>

</odoo>
